APP_NAME=KoG Team Planner API
APP_ENV=development
DEBUG=false

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Request tuning
REQUEST_TIMEOUT_SECONDS=30
MAP_CACHE_TTL_SECONDS=21600
PLAYER_CACHE_TTL_SECONDS=1800
PLAYER_CACHE_REDIS_URL=
KOG_TIMEZONE=UTC

# Optional Cloudflare/session cookies
KOG_CF_CLEARANCE=
KOG_PHPSESSID=

# Optional fallback for local experimentation
KOG_BOOTSTRAP_BROWSER=false
