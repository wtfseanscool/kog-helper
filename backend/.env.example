APP_NAME=KoG Team Planner API
APP_ENV=development
DEBUG=false

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Request tuning
REQUEST_TIMEOUT_SECONDS=30
MAP_CACHE_TTL_SECONDS=21600
PLAYER_CACHE_TTL_SECONDS=1800
PLAYER_CACHE_REDIS_URL=
KOG_TIMEZONE=UTC

# Optional Cloudflare/session cookies
KOG_CF_CLEARANCE=
KOG_PHPSESSID=

# Optional fallback for local experimentation
KOG_BOOTSTRAP_BROWSER=false

# Frontend URL used for OAuth redirects and post-login navigation
FRONTEND_BASE_URL=http://127.0.0.1:5173

# Optional public backend base URL for OAuth callbacks (set in production behind proxies)
AUTH_REDIRECT_BASE_URL=

# Auth/session settings
AUTH_SECRET_KEY=change-me-in-production
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_COOKIE_SECURE=false
AUTH_DB_PATH=backend/data/auth.db

# OAuth provider credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
